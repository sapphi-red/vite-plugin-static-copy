{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:monthly",
    "group:allNonMajor",
    "helpers:disableTypesNodeMajor"
  ],
  "labels": ["dependencies"],
  "ignorePaths": ["**/node_modules/**"],
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "matchDepTypes": ["action"],
      "pinDigests": true
    },
    {
      "matchDepTypes": ["npm"],
      "minimumReleaseAge": "1440 minutes"
    }
  ],
  "ignoreDeps": ["node"]
}
